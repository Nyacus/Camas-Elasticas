rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    match /parks/{parkId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /sessions/{sessionId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.parkId is string
        && request.resource.data.bedNumber is number
        && request.resource.data.durationMinutes is number
        && request.resource.data.day is string
        && request.resource.data.status == 'active';
      allow update: if signedIn()
        && resource.data.parkId == request.resource.data.parkId
        && request.resource.data.status in ['active', 'finished', 'replaced'];
      allow delete: if false;
    }
  }
}
